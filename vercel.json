{
  "rewrites": [
    { "source": "/privacy", "destination": "/legal/privacy.html" },
    { "source": "/terms", "destination": "/legal/terms.html" },
    { "source": "/u/:handle", "destination": "/?profile=:handle" },
    { "source": "/u/:handle/:tab", "destination": "/?profile=:handle&tab=:tab" },
    { "source": "/s/:id/chat", "destination": "/" },
    { "source": "/s/:id", "destination": "/" },
    { "source": "/api/me/guilds/refresh", "destination": "/api/me?action=guilds-refresh" },
    { "source": "/api/me/guilds/:guildId", "destination": "/api/me?action=guild&guildId=:guildId" },
    { "source": "/api/me/guilds", "destination": "/api/me?action=guilds" },
    { "source": "/api/me/prefs", "destination": "/api/me?action=prefs" },
    { "source": "/api/me/settings", "destination": "/api/me?action=settings" },
    { "source": "/api/me/community", "destination": "/api/me?action=community" },
    { "source": "/api/me/community-members", "destination": "/api/me?action=community-members" },
    { "source": "/api/me/community-activity", "destination": "/api/me?action=community-activity" },
    { "source": "/api/me/recent-partners", "destination": "/api/me?action=recent-partners" },
    { "source": "/api/me/favorites/:handle", "destination": "/api/me?action=favorite-delete&handle=:handle" },
    { "source": "/api/me/favorites", "destination": "/api/me?action=favorites" },
    { "source": "/api/me/feedback", "destination": "/api/me?action=feedback" },
    { "source": "/api/prices", "destination": "/api/me?action=prices" },
    { "source": "/api/sync/wants", "destination": "/api/sync?kind=wants" },
    { "source": "/api/sync/available", "destination": "/api/sync?kind=available" },
    { "source": "/api/auth/me", "destination": "/api/auth?action=me" },
    { "source": "/api/auth/discord", "destination": "/api/auth?action=discord" },
    { "source": "/api/auth/callback", "destination": "/api/auth?action=callback" },
    { "source": "/api/auth/logout", "destination": "/api/auth?action=logout" },
    { "source": "/api/auth/dismiss-merge-banner", "destination": "/api/auth?action=dismiss-merge-banner" },
    { "source": "/api/bot/interactions", "destination": "/api/bot?action=interactions" },
    { "source": "/api/bot/events", "destination": "/api/bot?action=events" },
    { "source": "/api/cron/signals", "destination": "/api/bot?action=cron-signals" },
    { "source": "/api/cron/session-followups", "destination": "/api/bot?action=cron-session-followups" },
    { "source": "/api/me/sessions", "destination": "/api/sessions?action=list" },
    { "source": "/api/sessions/create", "destination": "/api/sessions?action=create" },
    { "source": "/api/sessions/create-open", "destination": "/api/sessions?action=create-open" },
    { "source": "/api/sessions/:id/edit", "destination": "/api/sessions?action=edit&id=:id" },
    { "source": "/api/sessions/:id/confirm", "destination": "/api/sessions?action=confirm&id=:id" },
    { "source": "/api/sessions/:id/unconfirm", "destination": "/api/sessions?action=unconfirm&id=:id" },
    { "source": "/api/sessions/:id/cancel", "destination": "/api/sessions?action=cancel&id=:id" },
    { "source": "/api/sessions/:id/decline", "destination": "/api/sessions?action=decline&id=:id" },
    { "source": "/api/sessions/:id/claim", "destination": "/api/sessions?action=claim&id=:id" },
    { "source": "/api/sessions/:id/invite-handle", "destination": "/api/sessions?action=invite-handle&id=:id" },
    { "source": "/api/sessions/:id/chat", "destination": "/api/sessions?action=chat&id=:id" },
    { "source": "/api/sessions/:id/mark-read", "destination": "/api/sessions?action=mark-read&id=:id" },
    { "source": "/api/sessions/:id/suggest", "destination": "/api/sessions?action=suggest&id=:id" },
    { "source": "/api/sessions/:id/suggestion/:suggestionId/accept", "destination": "/api/sessions?action=accept-suggestion&id=:id&suggestionId=:suggestionId" },
    { "source": "/api/sessions/:id/suggestion/:suggestionId/dismiss", "destination": "/api/sessions?action=dismiss-suggestion&id=:id&suggestionId=:suggestionId" },
    { "source": "/api/sessions/:id/propose-revert", "destination": "/api/sessions?action=propose-revert&id=:id" },
    { "source": "/api/sessions/:id", "destination": "/api/sessions?action=get&id=:id" },
    { "source": "/api/signals/mine", "destination": "/api/signals?action=mine" },
    { "source": "/api/signals/seed", "destination": "/api/signals?action=seed" },
    { "source": "/api/signals/:groupId/cancel", "destination": "/api/signals?action=cancel&groupId=:groupId" },
    { "source": "/api/signals/create", "destination": "/api/signals?action=create" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron/signals",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/session-followups",
      "schedule": "*/2 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate, s-maxage=0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate, s-maxage=0" }
      ]
    }
  ]
}
