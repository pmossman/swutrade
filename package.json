{
  "name": "swutrade",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gen:fonts": "tsx scripts/gen-fonts.ts",
    "fetch-prices": "tsx scripts/fetch-prices.ts",
    "fetch-prices:force": "FETCH_PRICES=1 tsx scripts/fetch-prices.ts",
    "enrich-cards": "tsx scripts/enrich-cards.ts",
    "enrich-cards:force": "ENRICH=1 tsx scripts/enrich-cards.ts",
    "build": "tsx scripts/fetch-prices.ts && tsx scripts/enrich-cards.ts && tsc -b && vite build",
    "build:fresh": "FETCH_PRICES=1 tsx scripts/fetch-prices.ts && ENRICH=1 tsx scripts/enrich-cards.ts && tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.4",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^3.2.4"
  }
}
